```{r setup, include=FALSE}
library(sf)
library(dplyr)
library(tmap)
knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE)
```

```{r data_processing}
# Загрузка данных
track_points <- st_read("G:/track.gpx", layer = "track_points") %>%
  st_transform(32637) %>% 
  select(time, geometry)

track_pre <- track_points %>% mutate(index = row_number())
base_point <- track_pre[1, ]
entry_point <- track_pre[100, ] 

# Точка перехода
track_pre$dist_temp <- as.numeric(st_distance(track_pre$geometry, entry_point))
entry_point_idx <- track_pre %>%
  filter(index > 300 & index < 600) %>%
  filter(dist_temp == min(dist_temp)) %>%
  pull(index)

# созданная Точка стыка
pt_before <- track_pre[entry_point_idx - 1, ]
pt_after  <- track_pre[entry_point_idx, ]

mid_point <- pt_before
mid_point$geometry <- (pt_before$geometry + pt_after$geometry) / 2
mid_point$time <- pt_before$time + (pt_after$time - pt_before$time) / 2
mid_point$index <- entry_point_idx - 0.5
st_crs(mid_point) <- st_crs(track_pre)

# Расчёты
track_analyzed <- rbind(track_pre, mid_point) %>%
  arrange(time) %>%
  mutate(
    index_new = row_number(),
    dist_to_base = as.numeric(st_distance(geometry, base_point)),
    dist_step = as.numeric(st_distance(geometry, lag(geometry), by_element = TRUE)),
    dt = as.numeric(difftime(time, lag(time), units = "secs")),
    speed = (dist_step / dt) * 3.6
  )

mid_idx_final <- which(track_analyzed$index == entry_point_idx - 0.5)

track <- track_analyzed %>%
  mutate(Участок = case_when(
    index_new <= 100 ~ "Подход к трассе",
    index_new >= 100 & index_new <= mid_idx_final ~ "Круг 1",
    index_new >= mid_idx_final & index_new <= (n() - 130) ~ "Круг 2",
    TRUE ~ "Уход с трассы"
  )) %>%
  filter(!is.na(dist_step))
```

```{r stats_table}
# Таблица расчётов
stats <- track %>%
  st_drop_geometry() %>%
  group_by(Участок) %>%
  summarise(
    Длина_км = sum(dist_step, na.rm = TRUE) / 1000,
    Время_ч = as.numeric(difftime(max(time), min(time), units = "hours")),
    Ср_скорость_км_ч = Длина_км / Время_ч,
    Начало = format(min(time), "%H:%M:%S"), 
    Конец = format(max(time), "%H:%M:%S"),
    Неравномерность = round(sd(speed, na.rm = TRUE) / mean(speed, na.rm = TRUE), 2)
  ) %>%
  mutate(
    Длина_км = round(Длина_км, 2),
    Время_ч = round(Время_ч, 3),
    Ср_скорость_км_ч = round(Ср_скорость_км_ч, 1)
  )

knitr::kable(stats)
```

```{r max_dist}
# Считаем максимальное удаление от базы
max_dist <- max(track_analyzed$dist_to_base, na.rm = TRUE)
cat("Максимальное удаление от базы:", round(max_dist, 0), "метров")
```

```{r map}
# Рисуем
tmap_mode("plot")
full_extent <- st_bbox(track)

l1 <- track %>% filter(Участок == "Подход к трассе") %>% summarise(do_union=F) %>% st_cast("LINESTRING")
l2 <- track %>% filter(Участок == "Круг 1") %>% summarise(do_union=F) %>% st_cast("LINESTRING")
l3 <- track %>% filter(Участок == "Круг 2") %>% summarise(do_union=F) %>% st_cast("LINESTRING")
l4 <- track %>% filter(Участок == "Уход с трассы") %>% summarise(do_union=F) %>% st_cast("LINESTRING")

tm_basemap("OpenStreetMap") + 
  tm_shape(l1, bbox = full_extent) + tm_lines(col = "blue", lwd = 5) +
  tm_shape(l2) + tm_lines(col = "red", lwd = 5) +
  tm_shape(l3) + tm_lines(col = "orange", lwd = 5) +
  tm_shape(l4) + tm_lines(col = "green", lwd = 5) +
  tm_shape(base_point) + tm_symbols(col = "black", shape = 4, size = 0.5) +
  tm_add_legend(type = "line", 
                labels = c("Подход", "Круг 1", "Круг 2", "Уход"),
                col = c("blue", "red", "orange", "green"), lwd = 3, title = "") +
  tm_layout(main.title = "Анализ лыжной трассы", 
            legend.outside = TRUE, legend.frame = TRUE, frame = TRUE) +
  tm_scalebar(position = c("right", "bottom"), bg.color = "white", bg.alpha = 0.5)
```
